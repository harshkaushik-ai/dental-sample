# Copy this file to .env and fill in your values

# SQLite (local dev) — change to PostgreSQL for production
DATABASE_URL="file:./dev.db"

# Change this to a long random secret string in production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Used once to create the first admin account via /api/admin/setup
ADMIN_SETUP_KEY="your-setup-key-change-this"
